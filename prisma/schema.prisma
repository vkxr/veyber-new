generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id               String   @id @default(cuid())
  businessName     String
  businessType     String
  googleReviewLink String
  location         String?
  tone             String?
  customPrompt     String?
  payment          Json?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
}
